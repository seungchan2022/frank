{
  "mcpServers": {
    "tuist": {
      "type": "stdio",
      "command": "tuist",
      "args": ["mcp", "start"]
    },
    "codex": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/codex",
      "args": ["mcp-server", "-c", "model=\"gpt-5.1-codex-mini\""],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  }
}
